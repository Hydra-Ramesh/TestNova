# ============================================
# TestNova Environment Variables
# ============================================

# MongoDB
MONGO_URI=mongodb://localhost:27017/testnova

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@testnova.com

# Frontend URL
CLIENT_URL=http://localhost:5173

# Backend
PORT=5000
NODE_ENV=development

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Groq API Keys (up to 10 for rotation)
GROQ_KEY_1=gsk_your_key_1
GROQ_KEY_2=gsk_your_key_2
GROQ_KEY_3=gsk_your_key_3
GROQ_KEY_4=gsk_your_key_4
GROQ_KEY_5=gsk_your_key_5
GROQ_KEY_6=gsk_your_key_6
GROQ_KEY_7=gsk_your_key_7
GROQ_KEY_8=gsk_your_key_8
GROQ_KEY_9=gsk_your_key_9
GROQ_KEY_10=gsk_your_key_10

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Groq Model Config
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.1-8b-instant
