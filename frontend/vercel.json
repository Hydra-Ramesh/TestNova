{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://testnova-backend.onrender.com/api/:path*" },
    { "source": "/socket.io/:path*", "destination": "https://testnova-backend.onrender.com/socket.io/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
